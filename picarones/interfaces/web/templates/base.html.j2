{# Picarones — base de la SPA (refonte XerOCR).
 #
 # Shell de l'application : sidebar gauche (rail) + colonne principale.
 # Variables attendues (passées par `render_index`) :
 #   - lang    : code langue ("fr" ou "en")
 #   - version : version Picarones (cache-busting des statics)
 #
 # Tout le DOM dynamique est manipulé par `web-app.js` (vanilla).
 # Les IDs et class historiques (#view-*, .view, .nav-btn, etc.) sont
 # préservés en plus des nouvelles class XerOCR pour ne pas casser
 # le binding JS existant.
#}<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="picarones-lang" content="{{ lang }}">
<title>Picarones — OCR Benchmark</title>
<link rel="stylesheet" href="/static/picarones.css?v={{ version }}">
</head>
<body>

<div class="app">

  {% include '_rail.html' %}

  <main class="main" id="main">
    {% include '_view_benchmark.html' %}
    {% include '_view_import.html' %}
    {% include '_view_reports.html' %}
    {% include '_view_engines.html' %}
  </main>

</div>

{% include '_modals.html' %}

<script src="/static/web-app.js?v={{ version }}"></script>
</body>
</html>
